# Plex — required (or configure via the Settings tab in the UI)
PLEX_TOKEN=
PLEX_URL=

# TMDB — required for series/collection enrichment
TMDB_API_KEY=

# Radarr — optional, enables adding missing movies
RADARR_URL=
RADARR_API_KEY=
RADARR_PROFILE=
RADARR_FOLDER=

# Sonarr — optional, enables adding missing TV shows
SONARR_URL=
SONARR_API_KEY=
SONARR_PROFILE=
SONARR_FOLDER=

# Database path (default: cache.sqlite in project root; /data/cache.sqlite for Docker)
# CACHE_DB_PATH=/data/cache.sqlite
